{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    "helpers:pinGitHubActionDigests"
  ],
  "schedule": ["before 4am on Monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all non-major Go module updates into a single weekly PR.",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go-mod non-major"
    },
    {
      "description": "Pin GitHub Actions by SHA; auto-merge patch/minor bumps.",
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "mise tools: batch updates.",
      "matchManagers": ["mise"],
      "groupName": "mise tools"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "enabled": true
  },
  "osvVulnerabilityAlerts": true
}
